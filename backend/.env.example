# Crowd backend config (copy to backend/.env and load via your process manager, or export in the shell).
# All have safe local-dev defaults; set real values in production.

PORT=8787

# Salt for hashing IPs. MUST be set to a long random secret in production (never store raw IPs).
IP_SALT=change-me-to-a-long-random-secret

# CORS: the GitHub Pages origin in production, e.g. https://you.github.io
ALLOWED_ORIGIN=*

# Cloudflare Turnstile secret. Leave empty to DISABLE bot checks (local dev only).
TURNSTILE_SECRET=

# Abuse caps per salted IP-hash per day.
MAX_REPORTS_PER_IP_DAY=60
MAX_FEEDBACK_PER_IP_DAY=10

# SQLite path (defaults to backend/safetymap.db).
# DB_PATH=
