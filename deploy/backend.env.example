# Production environment for the SafetyMap backend.
# Install to /etc/safetymap/backend.env and `chmod 600` it (it holds the IP salt).
# NOTE: this is a systemd EnvironmentFile — it parses KEY=VALUE literally.
#       Do NOT wrap values in quotes and do NOT use `export`.

PORT=8787

# Secret used to hash IPs (the app never stores raw IPs). MUST be long & random.
# Generate one with:  openssl rand -hex 32
IP_SALT=CHANGE_ME_run_openssl_rand_hex_32

# CORS allow-list = your deployed map's ORIGIN (scheme + host, no path).
ALLOWED_ORIGIN=https://latam-safety-map.com

# Optional Cloudflare Turnstile secret. Empty = bot checks disabled.
TURNSTILE_SECRET=

# Per-IP/day abuse caps.
MAX_REPORTS_PER_IP_DAY=60
MAX_FEEDBACK_PER_IP_DAY=10

# Persistent SQLite path (writable via the unit's StateDirectory=safetymap).
DB_PATH=/var/lib/safetymap/safetymap.db
